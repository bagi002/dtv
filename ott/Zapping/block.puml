@startuml block_ott_zapping
title Zapping - ott

skinparam shadowing false
skinparam rectangle {
  BackgroundColor<<active>> #CFE8CF
  BorderColor<<active>> #2E7D32
  BackgroundColor<<idle>> #EEEEEE
  BorderColor<<idle>> #BDBDBD
  FontColor<<idle>> #888888
}
legend top right
  <back:#CFE8CF> aktivno </back>  blok se koristi u OTT playback-u (HTTP -> ExoPlayer -> A/V)
  <back:#EEEEEE> idle </back>  postoji u stacku, ne koristi se pri OTT zap-u
endlegend

rectangle "APPLICATION" {
  rectangle "Live TV App" <<active>> as LiveTV
}

rectangle "MIDDLEWARE / AL" {
  rectangle "TV Input Framework\n(TV Input Manager)" <<active>> as TIF
  rectangle "OTT TV Input\n(TvInputService)" <<active>> as TIS
  rectangle "OTT client\n(resolve stream URL)" <<active>> as OTT
  rectangle "ExoPlayer / Media3 (core)\nTrackSelector + LoadControl" <<active>> as PLAYER
  rectangle "HLS / DASH MediaSource" <<active>> as SRC
  rectangle "TV Provider (read URL)" <<active>> as TVP
}

rectangle "PLATFORM / PAL / OS" {
  rectangle "HTTP DataSource\n(OkHttp / Cronet / DefaultHttpDataSource)" <<active>> as HTTP
  rectangle "MediaCodec (video)" <<active>> as MC
  rectangle "AudioTrack (audio)" <<active>> as AT
  rectangle "TLS / SSL + common libs" <<active>> as TLS
}

rectangle "DRIVERS / HAL" {
  rectangle "Network\n(Wi-Fi / Ethernet NIC)" <<active>> as NET
  rectangle "VDEC" <<active>> as VDEC
  rectangle "ADEC" <<active>> as ADEC
  rectangle "GPU / Display" <<active>> as GPU
  rectangle "TUNER" <<idle>> as TUNER
  rectangle "DEMUX" <<idle>> as DEMUX
}

LiveTV --> TIF
TIF --> TIS
TIS --> TVP
TIS --> OTT
TIS --> PLAYER
PLAYER --> SRC
SRC --> HTTP
HTTP --> TLS
TLS --> NET
HTTP --> NET
PLAYER --> MC
MC --> VDEC
VDEC --> GPU
PLAYER --> AT
AT --> ADEC
PLAYER --> GPU : video surface
@enduml
