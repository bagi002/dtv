@startuml block_ott_service_installation
title Service Installation - ott

skinparam shadowing false
skinparam rectangle {
  BackgroundColor<<active>> #CFE8CF
  BorderColor<<active>> #2E7D32
  BackgroundColor<<idle>> #EEEEEE
  BorderColor<<idle>> #BDBDBD
  FontColor<<idle>> #888888
}
legend top right
  <back:#CFE8CF> aktivno </back>  blok se koristi pri OTT instalaciji (povlacenje liste sa servera)
  <back:#EEEEEE> idle </back>  postoji u stacku, ne koristi se pri instalaciji
endlegend

rectangle "APPLICATION" {
  rectangle "Live TV App" <<active>> as LiveTV
}

rectangle "MIDDLEWARE / AL" {
  rectangle "TV Input Framework\n(TV Input Manager)" <<active>> as TIF
  rectangle "TV Provider\n(channels/programs DB)" <<active>> as TVP
  rectangle "OTT TV Input\n(TvInputService)" <<active>> as TIS
  rectangle "OTT client (HTTP fetch)" <<active>> as OTT
  rectangle "Metadata parser\n(JSON / XML)" <<active>> as PARSE
  rectangle "ExoPlayer / Media3" <<idle>> as PLAYER
}

rectangle "PLATFORM / PAL / OS" {
  rectangle "HTTP stack\n(OkHttp / Cronet / HttpURLConnection)" <<active>> as HTTP
  rectangle "JSON/XML libs\n(Gson / Moshi / XmlPullParser)" <<active>> as JSON
  rectangle "TLS / SSL + common libs" <<active>> as TLS
  rectangle "MediaCodec / AudioTrack" <<idle>> as AVSDK
}

rectangle "DRIVERS / HAL" {
  rectangle "Network\n(Wi-Fi / Ethernet NIC)" <<active>> as NET
  rectangle "TUNER" <<idle>> as TUNER
  rectangle "DEMUX" <<idle>> as DEMUX
  rectangle "VDEC" <<idle>> as VDEC
  rectangle "ADEC" <<idle>> as ADEC
}

LiveTV --> TIF
TIF --> TIS
TIS --> OTT
OTT --> PARSE
OTT --> HTTP
PARSE --> JSON
HTTP --> TLS
TLS --> NET
HTTP --> NET
TIS --> TVP
PARSE ..> TVP : publish OTT services (channels + stream URL)
@enduml
