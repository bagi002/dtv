@startuml sequence_service_installation
title Broadcast - Service Installation (Scan) - UML sequence
' Bazirano na Module 7, Figure 4 (channel scanning) + scanByUrl (Cuttlefish, .ts fajl)

actor User
participant "Live TV App" as App
participant "Broadcast TV Input" as TIS
participant "Comedia Service API" as CS
participant "Comedia MAL" as MAL
participant "Comedia MW core" as MW
participant "Comedia CHAL TDAL" as CHAL
participant "Android TV Provider" as TVP

User -> App : Initiate scan (first-time install)
App -> TIS : start scan
TIS -> CS : startScanByUrl("file:///data/clear_0002.ts", append=false)
activate CS
CS -> MAL : routeManagerGetInstallRoute()
MAL -> MW : MAL_TUNER_AutoScanURL()
activate MW
MW -> MW : IPINSTALL_SetCurrentRoute()\ncmIPINSTALL_Initiate()\ncmIPINSTALL_SetScanningMode()
MW -> CHAL : TDAL_IP_DMD_Tune()
activate CHAL
CHAL -> CHAL : FindProtocol('file')\nfile_setup()\nfile_open('/data/clear_0002.ts')
CHAL --> MW : IPINSTALL_DMD_StatusCallback(eDMD_LOCKED)
deactivate CHAL
MW --> TIS : TUNER_EVENT_INSTALL_PROGRESS
TIS --> App : install progress

group Table parsing (software demux channel)
  MW -> CHAL : IPINSTALL_DMD_TdalTsConnect() -> createChannel(SECTION)
  MW -> MW : parse PAT -> PMT -> SDT
  MW --> CS : IPINSTALL_DMD_PI_ServiceListCallBack(ePI_OK)\n[ONID=0x7780, SID=0x0065, name]
  MW -> MW : write service to Service and Mux DB (SList+PIDB)
  MW --> TIS : TUNER_EVENT_INSTALL_PROGRESS
end

loop while services remain in TS
  MW -> MW : IPINSTALL_DMD_ContinueInstall() / IPINSTALL_DMD_ScanContinue()
end

group Cleanup
  CHAL -> CHAL : file_close() / file_teardown() / Interface UNLOCKED
  MW -> CHAL : IPINSTALL_DMD_TdalTsDisconnect() (SoftwareDmxChannel close)
  MW -> MAL : IPINSTALL_DMD_InstallCompleted() / routeManagerReleaseRoute()
end
MW --> CS : TUNER_EVENT_INSTALL_COMPLETE
deactivate MW
CS --> TIS : install complete
deactivate CS
TIS -> TVP : insert/update channels (publish services)
TIS --> App : Scan complete
@enduml
