@startuml sequence_service_installation_liba4tv_v2
title Service Installation - brodcast
' Sabloni: Module 5 Fig.3, Module 6 Fig.2/3 (platform/HAL), Fig.4 (tune), Fig.6 (table parsing), Module 7 Fig.4 (scan)

actor User
box "Android app" #EBF5FF
  participant "Live TV App" as App
  participant "Broadcast TvInputService" as TIS
end box
box "Comedia - iWedia liba4tv" #E8F5E9
  participant "ComediaRouteManagerControl" as ROUTE
  participant "ScanControl" as SCAN
  participant "ServiceControl" as SVC
  participant "Comedia CHAL - TDAL" as CHAL
end box
box "Ispod Comedije - Platform i HAL - demonstration" #FFF3E0
  participant "Tuner SDK / Tuner HAL" as TSDK
end box
participant "Android TV Provider" as TVP

User -> App : Initiate scan (first-time install)
App -> TIS : start scan
TIS -> ROUTE : getInstallRoute(RouteManagerMediumType.MEDIUM_IP)
ROUTE --> TIS : routeID
note over ROUTE : MEDIUM_IP = file/URL scan (Cuttlefish); MEDIUM_TER za pravi terrestrial
TIS -> SCAN : registerListener(scanListener)
TIS -> SCAN : appendList(false)
TIS -> SCAN : autoScan(routeID, "file:///data/clear_0002.ts")

note over SCAN,CHAL : Comedia interno: install route -> CHAL (TDAL_DMD / TDAL_DMX)
SCAN -> CHAL : pokreni install na ruti
CHAL -> TSDK : tune (file izvor) + otvori section filtere PAT/PMT/SDT
note over TSDK : demonstration: frontend tune + demux section filteri\nkomunicira sa HAL (TUNER/DEMUX) -> Nexus/Magnum (ref. Module 6 Fig.4, Fig.6)
TSDK --> CHAL : locked + sekcije dostupne
CHAL --> SCAN : izvor spreman / tabele parsirane

SCAN --> TIS : tunerLocked(routeId, true)
SCAN --> TIS : scanProgressChanged(routeId, value)
SCAN --> TIS : installStatus(ScanInstallStatus)
loop za svaki servis (PAT -> PMT -> SDT)
  SCAN --> TIS : installServiceTVName(routeId, name)
  SCAN --> TIS : installServiceTVNumber(routeId, number)
end
SCAN --> TIS : scanFinished(routeId)

TIS -> SVC : getServiceListCount(listIndex)
TIS -> SVC : getServiceDescriptor(listIndex, serviceIndex)
SVC --> TIS : ServiceDescriptor (getName, getONID, getTSID, getServiceId)
TIS -> TVP : insert/update channels (TvContract.Channels)
TIS -> SCAN : unregisterListener(scanListener)
TIS --> App : Scan complete
@enduml
