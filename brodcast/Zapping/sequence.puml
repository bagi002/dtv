@startuml sequence_zapping
title Broadcast - Zapping - UML sequence
' Bazirano na Module 7, Figure 5 (broadcast zapping) + Module 6, Figure 4/5

actor User
participant "Live TV App" as App
participant "Broadcast TV Input" as TIS
participant "Comedia Service API" as CS
participant "Comedia MAL" as MAL
participant "Comedia MW / XSERV" as MW
participant "Comedia CHAL TDAL" as CHAL
participant "MediaCodec" as MC
participant "AudioTrack" as AT

User -> App : Play channel 1
App -> TIS : onSetSurface(surface)
App -> TIS : onSetStreamVolume(0.0)\n[mute tokom switcha]
App -> TIS : onTune(content://.../channels/1)
TIS -> CS : setCurrentServiceByTriplet(ONID, TSID, SID)
activate CS
CS -> MAL : routeManagerGetLiveRoute()
MAL -> MW : MAL_SZ_StartTripletService(serviceIndex)
note over MAL,MW : ASINHRONO - posalje poruku u MAL_SZ_MainZapperTask (svoj thread)
activate MW

MW -> CHAL : TDAL_IP_DMD_Tune("file:///data/clear_0002.ts") -> file_open()
CHAL --> MW : File opened (locked)
MW -> MW : VideoBuffer_Allocate / ReadProto START (offthread)
MW -> MW : PI_EnableTsInformationAcquisition()
MW -> CHAL : createChannel(SECTION) za PAT/PMT (+EIT, +ECM/EMM ako scrambled)
MW -> MW : XSERV_Instance setup -> XSERV_Instance_SourceCallback(TSINFO_OK)
note over MW 000: components ready, PCR PID = 49

MW -> CHAL : createChannel(PCR) -> STC / AVChannel setup (lipsync)
MW -> MC : createChannel(VIDEO, H.264) -> allocate AVC decoder + configure
MW -> AT : createChannel(AUDIO) -> configure audio
MC -> MC : start (NEXUS_VideoDecoder_Start)
AT -> AT : start (NEXUS_AudioDecoder_Start)

MW --> MAL : MAL_SZ_NotifyServiceStarted
deactivate MW
MAL --> CS : service started (SID=0x65)
CS --> TIS : service started event
deactivate CS
TIS --> App : Service started -> Playback active
@enduml
