@startuml sequence_zapping_liba4tv_v5
title Zapping - broadcast (liba4tv)

actor User
box "Android app" #EBF5FF
  participant "Live TV App" as App
  participant "DtvTvInputService" as TIS
  participant "DtvTvInputSession" as SES
  participant "DtvTune" as TUNE
  participant "ChannelLookup" as CLKP
  participant "ChannelScanner" as CHSC
  participant "ChannelZapper" as ZAP
end box

box "liba4tv Java API (Android-facing wrapper)" #E8F5E9
  participant "ComediaRouteManagerControl" as ROUTE
  participant "DisplayControl" as DISP
  participant "ServiceControl" as SVC
  participant "ServiceListener\n(callback na ChannelZapper)" as SVCL
end box

box "Comedia native middleware" #FFF8E1
  participant "Comedia Core (MW)\nXSERV/Player + Table parser (PAT/PMT) + PTSM" as CORE
  database "Service & Mux DB\n(SList + PIDB)" as SDB
  participant "Comedia CHAL (TDAL)\nTDAL_DMD / TDAL_DMX / TDAL_AV / TDAL_DISP" as CHAL
end box

box "Platform / HAL - demonstration" #FFF3E0
  participant "Tuner SDK / Tuner HAL\n(Cuttlefish: .ts fajl kao izvor)" as TSDK
  participant "MediaCodec / AudioTrack" as AVDEC
end box

participant "Android TV Provider\n(TvContract.Channels)" as TVP

== TIF kreira sesiju ==

App -> TIS : onCreateSession(inputId)
TIS -> SES ** : new DtvTvInputSession(context, service, middlewareConnection)

== Korisnik bira kanal ==

User -> App : Play channel X
App -> SES : onSetSurface(surface)
App -> SES : onSetStreamVolume(volume)
App -> SES : onTune(channelUri)

SES -> SES : notifyVideoUnavailable(TUNING)
SES ->> TUNE : post(doTune)

== ChannelLookup: pronadji servis u MW listi ==

TUNE -> CLKP : findServiceIndex(contentResolver, serviceControl, channelUri)
CLKP -> TVP : query channelUri\n(ONID, TSID, ServiceId, INTERNAL_PROVIDER_DATA)
TVP --> CLKP : ChannelInfo (triplet + sourceUrl)
CLKP -> SVC : getServiceListCount(0) + getServiceDescriptor(0, i)
SVC -> SDB : upit nad Service & Mux DB
SDB --> SVC : ServiceDescriptor
CLKP -> CLKP : poredi ONID/TSID/SID

alt Servis NIJE u MW listi\n(multipleks obrisan jer je drugi izvor skeniran posle)
  CLKP --> TUNE : null
  TUNE -> CHSC : rescanSingleSource(sourceUrl, rescanCallback)
  CHSC --> TUNE : onRescanFinished(sourceUrl)
  TUNE -> CLKP : findServiceIndex(...) [ponovi pretragu]
  CLKP --> TUNE : Result (listIndex, serviceIndex, onid, tsid, serviceId)
else Servis JESTE u MW listi
  CLKP --> TUNE : Result (listIndex, serviceIndex, onid, tsid, serviceId)
end

== ChannelZapper: pokreni zapping ==

TUNE -> ZAP : startZap(listIndex, serviceIndex, onid, tsid, serviceId, surface)

ZAP -> ROUTE : getLiveRoute(listIndex, serviceIndex, prevRouteId)
ROUTE --> ZAP : liveRoute

ZAP -> DISP : setVideoSurface(0, SurfaceBundle(surface))
note over ZAP : surface se ne postavlja ponovo ako se nije promenio
DISP --> ZAP : A4TVStatus

ZAP -> SVC : registerListener(serviceListener)
ZAP -> SVC : startServiceByTriplet(liveRoute, listIndex, serviceIndex, onid, tsid, serviceId)
SVC --> ZAP : A4TVStatus

ZAP -> DISP : scaleWindow(liveRoute, 0, 0, 1920, 1080)

== Comedia native middleware ==

SVC -> CORE : pokreni playback na ruti (liveRoute)

note over CORE, SDB
 PAT/PMT su vec isparsirani tokom procesa instalacije servisa
end note

CORE -> SDB : ucitaj servis po tripletu (ONID/TSID/SID) iz Service & Mux DB
SDB --> CORE : PID-ovi servisa (video/audio PID, PCR PID, stream type)

CORE -> CHAL : TDAL_DMD - tune izvor (file/tuner) na ruti

CHAL -> TSDK : otvori protokol ('file') + otvori A/V i PCR PID filtere (PID-ovi iz PIDB)
TSDK --> CHAL : izvor zakljucan (locked) + PID-ovi dostupni

CHAL --> CORE : TDAL_DMX - A/V/PCR PID kanali spremni

CORE -> CHAL : TDAL_AV - otvori A/V kanale na PID-ovima (video/audio)
CHAL -> AVDEC : dekoduj video + audio; PCR/STC sync (lipsync)
note over AVDEC : demonstration: video+audio dekoder + display\nkomunicira sa HAL (VDEC/ADEC/GPU)
AVDEC --> CHAL : A/V tece, sinhronizovano
CHAL --> CORE : komponente spremne (PCR PID, A/V kanali aktivni)

CORE -> CHAL : TDAL_DISP - povezi dekodovani izlaz sa video surface-om
CHAL --> CORE : graphics/video plane spreman

== ServiceListener obavestava ChannelZapper da je zapping zavrsen ==

CORE --> SVC : servis pokrenut (interno)
SVC --> SVCL : channelChangeStatus(liveRoute, true, ServiceStateChangeError.OK)
SVCL --> ZAP : channelChangeStatus(liveRoute, true, OK)
ZAP --> TUNE : onChannelChanged(liveRoute) [via ResultListener]

SVC --> SVCL : safeToUnblank(liveRoute)
SVCL --> ZAP : safeToUnblank(liveRoute)
ZAP --> TUNE : onSafeToUnblank(liveRoute)

TUNE -> SES : notifyVideoAvailable()

@enduml
