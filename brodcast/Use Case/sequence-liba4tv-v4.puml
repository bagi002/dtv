@startuml sequence_subtitles_liba4tv_v4
title Subtitles - broadcast (liba4tv) - v4

actor User
box "Android app" #EBF5FF
  participant "Live TV App" as App
  participant "Broadcast TvInputService" as TIS
end box

box "liba4tv Java API (Android-facing wrapper)" #E8F5E9
  participant "SubtitleControl" as SUB
  participant "StreamComponentControl" as SC
  participant "DisplayControl" as DISP
end box

box "Comedia native middleware" #FFF8E1
  participant "Comedia Core (MW)\nTTX & Sub + PTSM" as CORE
  participant "Comedia CHAL (TDAL)\nTDAL_DMX / TDAL_GFX / TDAL_PTSM" as CHAL
end box

box "Platform / HAL - demonstration" #FFF3E0
  participant "Tuner SDK / Demux Filter" as TSDK
  participant "GPU / Display" as GPU
end box

TIS -> SUB : registerListener(subtitleListener)
TIS -> SC : registerListener(streamComponentListener)

== Comedia native middleware ==
CORE -> CHAL : TDAL_DMX - otvori subtitle PID filter (PID iz PIDB, vec upisan pri instalaciji)
CHAL -> TSDK : section/PES filter za subtitle elementary stream
TSDK --> CHAL : subtitle PES segmenti
CHAL --> CORE : subtitle komponenta aktivna na ruti

CORE -> SC : komponenta promijenjena (interno)
SC --> TIS : StreamComponentListener.componentChanged(routeID, StreamComponentType.SUBTITLE)

SUB --> TIS : SubtitleListener.updateTrackCount(SubtitleType.DVB, cnt)
TIS -> SUB : getSubtitleTrackCount(routeID)
SUB --> TIS : int cnt
loop za svaku raspoloživu traku
  TIS -> SUB : getSubtitleTrack(routeID, trackIndex)
  SUB --> TIS : SubtitleTrack
end

TIS -> SUB : setSubtitleType(SubtitleType.DVB)
TIS -> SUB : setCurrentSubtitleTrack(routeID, trackIndex)
SUB --> TIS : A4TVStatus
note right of SUB : Opciono: setSubtitleMode(SubtitleMode.HEARING_IMPAIRED)\nako PMT nudi varijantu za slušno oštećene/prevod

TIS -> SUB : enableAutomaticSubtitleDisplay(true)

== Aplikacija  prosledjuje graphics/overlay surface da bi se titl mogao prikazati ==
App -> TIS : onSetSurface(graphicsSurface)

TIS -> DISP : setGraficSurface(graphicsSurface)
DISP --> TIS : A4TVStatus
DISP -> CORE : graphics/overlay plane prosledjen middleware-u

CORE -> CHAL : TDAL_GFX - poveži graphics plane sa subtitle bitmap renderom
CHAL -> GPU : dekoduj bitmap segment + PCR/PTS sync (TDAL_PTSM); renderuj na graphics plane
GPU --> CHAL : bitmap composed preko video plane-a
CHAL --> CORE : subtitle prikazan na overlay surface-u

TIS -> SUB : getCurrentSubtitleTrackIndex(routeID)
SUB --> TIS : int trackIndex

TIS -> SUB : deselectCurrentSubtitleTrack(routeID)
SUB --> TIS : A4TVStatus

TIS -> SUB : unregisterListener(subtitleListener)
TIS -> SC : unregisterListener(streamComponentListener)

@enduml
