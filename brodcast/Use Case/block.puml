@startuml block_subtitles
title Broadcast - Subtitles (DVB) - Architecture Block Diagram (HAL/PAL/AL)
' Precondition: the service is already active (zapped) - see Zapping/block.puml.
' This diagram adds only the blocks specific to the subtitle flow.

skinparam shadowing false
skinparam rectangle {
  BackgroundColor<<active>> #CFE8CF
  BorderColor<<active>> #2E7D32
  BackgroundColor<<idle>> #EEEEEE
  BorderColor<<idle>> #BDBDBD
  FontColor<<idle>> #888888
}
legend top right
  <back:#CFE8CF> active </back>  block is used in the subtitle flow
  <back:#EEEEEE> idle </back>  exists in the stack (e.g. already active from the Zapping use case, or a related type such as Teletext), not the focus of this diagram
endlegend

rectangle "APPLICATION" {
  rectangle "Live TV App" <<active>> as LiveTV
}

rectangle "MIDDLEWARE / AL" {
  rectangle "TV Input Framework\n(TV Input Manager)" <<active>> as TIF
  rectangle "Broadcast TV Input\n(TvInputService)" <<active>> as TIS
  rectangle "Comedia DTV Middleware (Binder service)" {
    rectangle "Service Control / Player / XSERV\n(already active from Zapping)" <<idle>> as SVC
    rectangle "Table\n(PMT subtitle descriptor)" <<active>> as TABLE
    rectangle "TTX & Sub\n(subtitle parsing + PTS sync)" <<active>> as TTXSUB
    rectangle "CHAL - TDAL_DMX\n(subtitle PID channel)" <<active>> as DMX
    rectangle "CHAL - TDAL_PTSM\n(PTS synchronization)" <<active>> as PTSM
    rectangle "CHAL - TDAL_GFX\n(graphics/bitmap plane)" <<active>> as GFX
    rectangle "CHAL - TDAL_TTX\n(teletext, related type)" <<idle>> as TTX
  }
}

rectangle "PLATFORM / PAL / OS" {
  rectangle "Android Tuner SDK\n(Filter/Demux)" <<active>> as TUNERSDK
  rectangle "MediaCodec / AudioTrack\n(already active from Zapping)" <<idle>> as AVSDK
  rectangle "OS / common libs" <<idle>> as OSLIB
}

rectangle "DRIVERS / HAL" {
  rectangle "DEMUX\n(subtitle PID filter)" <<active>> as DEMUX
  rectangle "VDEC / ADEC\n(already active from Zapping)" <<idle>> as AVDEC
  rectangle "GPU / Display\n(composition, bitmap layering over video)" <<active>> as GPU
}

LiveTV --> TIF
TIF --> TIS
TIS --> SVC
SVC --> TABLE
TABLE --> TTXSUB
TTXSUB --> DMX
DMX --> TUNERSDK
TUNERSDK --> DEMUX
TTXSUB --> PTSM
TTXSUB --> GFX
GFX --> GPU
PTSM --> GFX
TTXSUB ..> TTX : related type, separate PID/parser
@enduml
