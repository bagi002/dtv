        <mxCell id="n147" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#A01512;fontSize=17;fontStyle=1;" value="Broadcast data-flow — call chain &quot;Zap to a Live TV service&quot; (maps directly to the UML sequence diagram)" vertex="1">
          <mxGeometry height="24" width="1280" x="695" y="1690" as="geometry" />
        </mxCell>
        <mxCell id="n148" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#5A6B7B;fontSize=11;fontStyle=2;" value="References: Module 7 (Broadcast Zapping / Channel Scanning), Module 6 (Broadcast Tune &amp; A/V Playback), Module 5 (call-stack across layers), liba4tv / Comedia API." vertex="1">
          <mxGeometry height="18" width="1280" x="695" y="1720" as="geometry" />
        </mxCell>
        <mxCell id="n149" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#D4231F;fontSize=12;fontStyle=1;" value="1" vertex="1">
          <mxGeometry height="18" width="24" x="695" y="1740" as="geometry" />
        </mxCell>
        <mxCell id="n150" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#23323F;fontSize=12;fontStyle=0;" value="Live TV App → Broadcast TV Input (TIS).  onTune(channelUri) (+ onSetSurface, onSetStreamVolume). &quot;Tune&quot; = activate this service, not RF tuning." vertex="1">
          <mxGeometry height="24" width="1260" x="721" y="1738" as="geometry" />
        </mxCell>
        <mxCell id="n151" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#D4231F;fontSize=12;fontStyle=1;" value="2" vertex="1">
          <mxGeometry height="18" width="24" x="695" y="1770" as="geometry" />
        </mxCell>
        <mxCell id="n152" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#23323F;fontSize=12;fontStyle=0;" value="Broadcast TV Input → Comedia API (Service, Java).  setCurrentServiceByTriplet(ONID,TSID,SID) → ServiceControl.startServiceByTriplet(routeID,list,svc,onid,tsid,sid)." vertex="1">
          <mxGeometry height="24" width="1260" x="721" y="1768" as="geometry" />
        </mxCell>
        <mxCell id="n153" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#D4231F;fontSize=12;fontStyle=1;" value="3" vertex="1">
          <mxGeometry height="18" width="24" x="695" y="1800" as="geometry" />
        </mxCell>
        <mxCell id="n154" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#23323F;fontSize=12;fontStyle=0;" value="Comedia Service (Java) → MAL (native).  JNI boundary → MAL_SZ_StartTripletService() posts to the async zapper task (returns immediately; result arrives as an event)." vertex="1">
          <mxGeometry height="24" width="1260" x="721" y="1798" as="geometry" />
        </mxCell>
        <mxCell id="n155" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#D4231F;fontSize=12;fontStyle=1;" value="4" vertex="1">
          <mxGeometry height="18" width="24" x="695" y="1830" as="geometry" />
        </mxCell>
        <mxCell id="n156" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#23323F;fontSize=12;fontStyle=0;" value="MAL → Comedia MW core (Route/Xserv, Service Control, Table).  getLiveRoute(...); Xserv orchestrates the signal path; Table parses PAT/PMT for A/V+PCR PIDs; stored in SList+PIDB." vertex="1">
          <mxGeometry height="24" width="1260" x="721" y="1828" as="geometry" />
        </mxCell>
        <mxCell id="n157" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#D4231F;fontSize=12;fontStyle=1;" value="5" vertex="1">
          <mxGeometry height="18" width="24" x="695" y="1860" as="geometry" />
        </mxCell>
        <mxCell id="n158" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#23323F;fontSize=12;fontStyle=0;" value="Comedia MW → Comedia CHAL (glue / TDAL_*).  TDAL_DMD (frontend/input), TDAL_DMX (demux/PID), TDAL_AV (decoders). CHAL hides Android-Tuner-SDK vs vendor-Nexus target." vertex="1">
          <mxGeometry height="24" width="1260" x="721" y="1858" as="geometry" />
        </mxCell>
        <mxCell id="n159" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#D4231F;fontSize=12;fontStyle=1;" value="6a" vertex="1">
          <mxGeometry height="18" width="24" x="695" y="1890" as="geometry" />
        </mxCell>
        <mxCell id="n160" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#23323F;fontSize=12;fontStyle=0;" value="CHAL → Tuner SDK (clean Android-aligned PAL).  Tuner.tune() → JNI → Tuner Native API → TRM.requestFrontend → Tuner HAL IFrontend.tune / IDemux.openFilter. A/V via MediaCodec + AudioTrack." vertex="1">
          <mxGeometry height="24" width="1260" x="721" y="1888" as="geometry" />
        </mxCell>
        <mxCell id="n161" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#D4231F;fontSize=12;fontStyle=1;" value="6b" vertex="1">
          <mxGeometry height="18" width="24" x="695" y="1920" as="geometry" />
        </mxCell>
        <mxCell id="n162" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#23323F;fontSize=12;fontStyle=0;" value="CHAL / Tuner HAL → Vendor DTV SDK (Broadcom NEXUS).  NEXUS_Frontend_Tune → InputBand→ParserBand→PidChannel → VideoDecoder/AudioDecoder_SetInput+Start → StcChannel (PCR) → VideoWindow→Display." vertex="1">
          <mxGeometry height="24" width="1260" x="721" y="1918" as="geometry" />
        </mxCell>
        <mxCell id="n163" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#D4231F;fontSize=12;fontStyle=1;" value="7" vertex="1">
          <mxGeometry height="18" width="24" x="695" y="1950" as="geometry" />
        </mxCell>
        <mxCell id="n164" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#23323F;fontSize=12;fontStyle=0;" value="NEXUS / Magnum → Drivers / HAL.  Memory-mapped register writes, buffer setup, IRQ handling against TUNER, DEMUX, VDEC, ADEC, GPU/Display. (Cuttlefish: a TS file feeds the input.)" vertex="1">
          <mxGeometry height="24" width="1260" x="721" y="1948" as="geometry" />
        </mxCell>
        <mxCell id="n165" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#D4231F;fontSize=12;fontStyle=1;" value="⟵" vertex="1">
          <mxGeometry height="18" width="24" x="695" y="1980" as="geometry" />
        </mxCell>
        <mxCell id="n166" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontColor=#23323F;fontSize=12;fontStyle=0;" value="Asynchronous return (dashed).  tunerLocked / lock → channelChangeStatus + safeToUnblank (ServiceListener) → MAL_SZ_NotifyServiceStarted → Comedia Service → TIS &quot;Service started&quot; → Live TV App." vertex="1">
